{
  "name": "@commercetools-applications/merchant-center-template-starter",
  "version": "27.7.0",
  "description": "A starter example for the bare minimum setup to develop a Merchant Center Application",
  "private": true,
  "scripts": {
    "build": "mc-scripts build",
    "start": "mc-scripts start",
    "compile-html": "mc-scripts compile-html",
    "compile-html:local": "MC_APP_ENV=development mc-scripts compile-html --transformer @commercetools-frontend/mc-dev-authentication/transformer-local.js",
    "start:prod:local": "npm run compile-html:local && mc-scripts serve",
    "extract-intl": "formatjs extract --format=./intl-formatter.js --out-file=./src/i18n/data/core.json 'src/**/!(*.spec).js'",
    "test": "jest --config jest.test.config.js",
    "test:watch": "jest --config jest.test.config.js --watch",
    "lint": "eslint .",
    "format": "prettier --write '**/*.js'",
    "versions:appkit": "manypkg upgrade @commercetools-frontend",
    "versions:uikit": "manypkg upgrade @commercetools-uikit"
  },
  "dependencies": {
    "@apollo/client": "catalog:apollo",
    "@babel/core": "catalog:build",
    "@babel/runtime-corejs3": "catalog:build",
    "@commercetools-frontend/actions-global": "workspace:^",
    "@commercetools-frontend/application-components": "workspace:^",
    "@commercetools-frontend/application-shell": "workspace:^",
    "@commercetools-frontend/application-shell-connectors": "workspace:^",
    "@commercetools-frontend/assets": "workspace:^",
    "@commercetools-frontend/babel-preset-mc-app": "workspace:^",
    "@commercetools-frontend/constants": "workspace:^",
    "@commercetools-frontend/eslint-config-mc-app": "workspace:^",
    "@commercetools-frontend/i18n": "workspace:^",
    "@commercetools-frontend/jest-preset-mc-app": "workspace:^",
    "@commercetools-frontend/l10n": "workspace:^",
    "@commercetools-frontend/mc-dev-authentication": "workspace:^",
    "@commercetools-frontend/mc-scripts": "workspace:^",
    "@commercetools-frontend/permissions": "workspace:^",
    "@commercetools-uikit/constraints": "catalog:repo",
    "@commercetools-uikit/data-table": "catalog:repo",
    "@commercetools-uikit/flat-button": "catalog:repo",
    "@commercetools-uikit/grid": "catalog:repo",
    "@commercetools-uikit/hooks": "catalog:repo",
    "@commercetools-uikit/icons": "catalog:repo",
    "@commercetools-uikit/link": "catalog:repo",
    "@commercetools-uikit/loading-spinner": "catalog:repo",
    "@commercetools-uikit/localized-text-field": "catalog:repo",
    "@commercetools-uikit/localized-text-input": "catalog:repo",
    "@commercetools-uikit/notifications": "catalog:repo",
    "@commercetools-uikit/pagination": "catalog:repo",
    "@commercetools-uikit/select-field": "catalog:repo",
    "@commercetools-uikit/spacings": "catalog:repo",
    "@commercetools-uikit/text": "catalog:repo",
    "@commercetools-uikit/text-field": "catalog:repo",
    "@commercetools-uikit/text-input": "catalog:repo",
    "@commercetools/composable-commerce-test-data": "catalog:",
    "@commercetools/sync-actions": "catalog:",
    "@emotion/react": "catalog:build",
    "@formatjs/cli": "catalog:formatjs",
    "@jest/types": "catalog:test",
    "@manypkg/cli": "catalog:repo",
    "@testing-library/dom": "catalog:test",
    "@testing-library/jest-dom": "catalog:test",
    "@testing-library/react": "catalog:test",
    "@types/jest": "catalog:test",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@types/react-router": "catalog:react",
    "@types/react-router-dom": "catalog:react",
    "@types/testing-library__jest-dom": "catalog:test",
    "eslint": "catalog:lint",
    "eslint-formatter-pretty": "catalog:lint",
    "formik": "catalog:react",
    "graphql": "catalog:apollo",
    "graphql-tag": "catalog:apollo",
    "jest": "catalog:test",
    "moment": "catalog:",
    "msw": "catalog:test",
    "omit-empty-es": "catalog:",
    "prettier": "catalog:lint",
    "prop-types": "catalog:react",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-intl": "catalog:react",
    "react-redux": "catalog:react",
    "react-router-dom": "catalog:react",
    "redux": "catalog:react"
  },
  "devDependencies": {
    "@graphql-eslint/eslint-plugin": "catalog:lint"
  },
  "resolutions": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@types/react-router": "<6",
    "@types/react-router-dom": "<6",
    "headers-polyfill": "3.2.5",
    "nwsapi": "2.2.7"
  },
  "overrides": {
    "lodash": ">=4.18.0",
    "serialize-javascript": ">=7.0.3",
    "vite": ">=6.4.2"
  }
}
