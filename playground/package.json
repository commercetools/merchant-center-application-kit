{
  "name": "@commercetools-local/playground",
  "version": "27.6.3",
  "description": "A playground application to get started developing Merchant Center Applications",
  "private": true,
  "scripts": {
    "build": "mc-scripts build",
    "start:server": "NODE_ENV=development && ts-node ./src/server.ts",
    "start": "mc-scripts start",
    "compile-html": "mc-scripts compile-html",
    "compile-html:local": "MC_APP_ENV=development mc-scripts compile-html --transformer @commercetools-frontend/mc-dev-authentication/transformer-local.js",
    "start:prod:local": "pnpm compile-html:local && mc-scripts serve",
    "extract-intl": "formatjs extract --format=./intl-formatter.js --out-file=./src/i18n/data/core.json 'src/**/!(*.spec).js'",
    "deploy": "vercel --scope=commercetools --confirm --no-clipboard"
  },
  "dependencies": {
    "@babel/runtime-corejs3": "catalog:build",
    "@commercetools-docs/ui-kit": "catalog:",
    "@commercetools-frontend/actions-global": "workspace:^",
    "@commercetools-frontend/application-components": "workspace:^",
    "@commercetools-frontend/application-shell": "workspace:^",
    "@commercetools-frontend/application-shell-connectors": "workspace:^",
    "@commercetools-frontend/assets": "workspace:^",
    "@commercetools-frontend/browser-history": "workspace:^",
    "@commercetools-frontend/constants": "workspace:^",
    "@commercetools-frontend/i18n": "workspace:^",
    "@commercetools-frontend/l10n": "workspace:^",
    "@commercetools-frontend/permissions": "workspace:^",
    "@commercetools-frontend/sdk": "workspace:^",
    "@commercetools-uikit/card": "catalog:repo",
    "@commercetools-uikit/checkbox-input": "catalog:repo",
    "@commercetools-uikit/constraints": "catalog:repo",
    "@commercetools-uikit/data-table": "catalog:repo",
    "@commercetools-uikit/date-time-input": "catalog:repo",
    "@commercetools-uikit/flat-button": "catalog:repo",
    "@commercetools-uikit/grid": "catalog:repo",
    "@commercetools-uikit/hooks": "catalog:repo",
    "@commercetools-uikit/icons": "catalog:repo",
    "@commercetools-uikit/label": "catalog:repo",
    "@commercetools-uikit/link": "catalog:repo",
    "@commercetools-uikit/loading-spinner": "catalog:repo",
    "@commercetools-uikit/notifications": "catalog:repo",
    "@commercetools-uikit/pagination": "catalog:repo",
    "@commercetools-uikit/primary-button": "catalog:repo",
    "@commercetools-uikit/secondary-button": "catalog:repo",
    "@commercetools-uikit/spacings": "catalog:repo",
    "@commercetools-uikit/text": "catalog:repo",
    "@emotion/react": "catalog:build",
    "@flopflip/react-broadcast": "catalog:flopflip",
    "apollo-link-rest": "catalog:apollo",
    "graphql": "catalog:apollo",
    "graphql-anywhere": "catalog:",
    "moment": "catalog:",
    "moment-timezone": "catalog:",
    "prop-types": "catalog:react",
    "qs": "catalog:",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-intl": "catalog:react",
    "react-router-dom": "catalog:react",
    "vercel": "catalog:"
  },
  "devDependencies": {
    "@commercetools-backend/express": "workspace:^",
    "@commercetools-frontend/mc-dev-authentication": "workspace:^",
    "@commercetools-frontend/mc-scripts": "workspace:^",
    "@commercetools/composable-commerce-test-data": "catalog:",
    "@formatjs/cli": "catalog:formatjs",
    "@types/jest": "catalog:test",
    "@types/node": "catalog:",
    "@types/testing-library__jest-dom": "catalog:test",
    "@vercel/node": "catalog:",
    "dotenv-flow": "catalog:",
    "express": "catalog:",
    "jest": "catalog:test",
    "msw": "catalog:test",
    "ts-node": "catalog:build",
    "typescript": "catalog:build"
  },
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=8"
  }
}
